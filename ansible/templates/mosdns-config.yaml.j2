log:
  level: info

data_providers:
  - tag: mac_addrs_remote
    file: /etc/mosdns/mac-address-remote.txt
    auto_reload: true
  - tag: mac_addrs_local
    file: /etc/mosdns/mac-address-local.txt
    auto_reload: true
  - tag: hosts
    file: /etc/mosdns/hosts
    auto_reload: true
  - tag: geosite
    file: /etc/mosdns/geosite.dat
    auto_reload: true

{% if mosdns_custom_forwarding is defined %}
{% for item in mosdns_custom_forwarding %}
{% for domain in item.domains %}
{% if domain.startswith('provider:') %}
{% set provider_tag = domain.split(':')[1] %}
  - tag: {{ provider_tag }}
    file: /etc/mosdns/{{ provider_tag | replace('_', '-') }}.txt
    auto_reload: true
{% endif %}
{% endfor %}
{% endfor %}
{% endif %}

plugins:
  # ── 基础插件 ──
  - tag: hosts
    type: hosts
    args:
      hosts:
        - "provider:hosts"

  - tag: match_type_https
    type: query_matcher
    args:
      qtype:
        - 65

  # ── MAC 地址匹配 ──
  - tag: match_clean_macs
    type: mac_matcher
    args:
      mac_address:
        - "provider:mac_addrs_remote"
        - "provider:mac_addrs_local"

  # ── 域名匹配（geosite） ──
  - tag: match_cn_domains
    type: query_matcher
    args:
      domain:
        - "provider:geosite:cn"

  # ── AdGuard 过滤引擎 ──
  - tag: adg_filter
    type: adg_filter
    args:
      block_lists:
{% for f in adguard_filters if f.enabled %}
        - url: "{{ f.url }}"
          name: "{{ f.name }}"
{% endfor %}
      allow_lists:
{% for f in adguard_whitelist_filters if f.enabled %}
        - url: "{{ f.url }}"
          name: "{{ f.name }}"
{% endfor %}
      block_mode: nxdomain
      update_interval: 3600
      cache_dir: "/etc/mosdns/adg_cache"

  # ── LRU 缓存（字节限制 LRU，两个路径共享） ──
  - tag: adg_cache
    type: adg_cache
    args:
      size: 52428800
      optimistic: true
      optimistic_ttl: 60
      prefetch: true
      prefetch_ttl: 30
      stale_ttl: 600

  # ── EDNS 选项过滤（转发前抹掉 65001 MAC 标记 和 ECS） ──
  - tag: strip_edns
    type: edns0_filter
    args:
      discard:
        - 65001
        - 8

  # ── 上游转发 ──

  # 自建非过滤转发
  - tag: forward_self_no_filter
    type: adg_forward
    args:
      mode: load_balance
      bootstrap:
{% for d in bootstrap_dns %}
        - "{{ d }}"
{% endfor %}
      upstream:
{% for u in mosdns_self_no_filter_upstream %}
        - addr: "{{ u }}"
{% endfor %}
      timeout: 10

  # 自建洁净过滤转发
  - tag: forward_self_clean
    type: adg_forward
    args:
      mode: load_balance
      bootstrap:
{% for d in bootstrap_dns %}
        - "{{ d }}"
{% endfor %}
      upstream:
{% for u in mosdns_self_clean_upstream %}
        - addr: "{{ u }}"
{% endfor %}
      timeout: 10

  # 海外转发
  - tag: forward_oversea
    type: adg_forward
    args:
      mode: load_balance
      bootstrap:
{% for d in bootstrap_dns %}
        - "{{ d }}"
{% endfor %}
      upstream:
{% for u in mosdns_oversea_upstream %}
        - addr: "{{ u }}"
{% endfor %}
      timeout: 10

  # 国内普通转发（兜底）
  - tag: forward_cn_normal
    type: adg_forward
    args:
      mode: load_balance
      bootstrap:
{% for d in bootstrap_dns %}
        - "{{ d }}"
{% endfor %}
      upstream:
{% for u in mosdns_cn_normal_upstream %}
        - addr: "{{ u }}"
{% endfor %}
      timeout: 10

{% if mosdns_custom_forwarding is defined %}
{% for item in mosdns_custom_forwarding %}
  - tag: "match_custom_{{ item.name }}"
    type: query_matcher
    args:
      domain:
{% for domain in item.domains %}
        - "{{ domain }}"
{% endfor %}

  - tag: "forward_custom_{{ item.name }}"
    type: adg_forward
    args:
      mode: load_balance
      bootstrap:
{% for d in bootstrap_dns %}
        - "{{ d }}"
{% endfor %}
      upstream:
{% for up in item.upstream %}
        - addr: "{{ up }}"
{% endfor %}
      timeout: {{ item.timeout | default(10) }}
{% endfor %}
{% endif %}

  # ── 非过滤兜底（非净化 MAC 走这个链路，抹掉 EDNS 再发往上游） ──
  - tag: no_filter_with_cn_fallback
    type: sequence
    args:
      exec:
        - strip_edns
        - primary:
            - forward_self_no_filter
          secondary:
            - forward_cn_normal
            - _return
          stat_length: 10
          threshold: 5
          fast_fallback: 1000
          always_standby: false

  # ── 主序列 ──
  - tag: default_sequence
    type: sequence
    args:
      exec:
        - hosts

{% if mosdns_custom_forwarding is defined %}
{% for item in mosdns_custom_forwarding %}
        - if: "match_custom_{{ item.name }}"
          exec:
{% if item.block_type_https | default(false) %}
            - if: "match_type_https"
              exec:
                - _new_empty_response
                - _return
{% endif %}
            - "forward_custom_{{ item.name }}"
            - if: "_response_valid_answer"
              exec:
                - _return
{% endfor %}
{% endif %}

        # 有 EDNS + 但是不匹配 MAC 地址
        - if: "_query_edns0 && !match_clean_macs"
          exec:
            # 无须过滤的
            - adg_cache
            # 此处含兜底逻辑
            - no_filter_with_cn_fallback
            - _return
        # 然后就是自己的设备走过滤
        - adg_filter
        - adg_cache
        - strip_edns
        # 这里要做一个比较复杂的回滚
        - primary:
            # 先发给自己的服务器,相当于默认都是这个
            - "forward_self_clean"
          secondary:
            # 但是如果公网的纯净解析炸了,那我们就分流自己处理
            # 模拟一个简单的公网自建服务器逻辑
            - if: (match_cn_domains)
              exec:
                - "adg_cache"
                - "forward_cn_normal"
                - _return
            # 剩下的就是请求海外了
            - "adg_cache"
            - "forward_oversea"
            - _return
          stat_length: 10
          threshold: 5
          fast_fallback: 5000
          always_standby: false

  # ── 应急/非过滤监听器（:1753，不过滤，全部走直出） ──
  - tag: unfilter_sequence
    type: sequence
    args:
      exec:
        - hosts
        - adg_cache
        - primary:
            - forward_self_no_filter
            - _return
          secondary:
            - forward_cn_normal
          stat_length: 10
          threshold: 5
          fast_fallback: 1000
          always_standby: false

servers:
  - exec: default_sequence
    timeout: 10
    listeners:
      - protocol: udp
        addr: ":{{ mosdns_default_listen }}"
      - protocol: tcp
        addr: ":{{ mosdns_default_listen }}"
  - exec: unfilter_sequence
    timeout: 5
    listeners:
      - protocol: udp
        addr: ":{{ mosdns_clean_listen | default(1753) }}"
      - protocol: tcp
        addr: ":{{ mosdns_clean_listen | default(1753) }}"
